<Window x:Class="L2Companion.UI.OverlayWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="L2 Companion HUD"
        Width="280"
        Height="364"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        MouseLeftButtonDown="OnMouseLeftButtonDown">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBrush" Color="#EE0D1117" />

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#CC1C2333" />
            <Setter Property="BorderBrush" Value="#5530363D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="7,5" />
        </Style>

        <Style x:Key="VitalBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Background" Value="#21262D" />
            <Setter Property="Foreground" Value="#3FB950" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#388BFD" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>
    </Window.Resources>

    <Border Margin="5"
            Background="{StaticResource ShellBrush}"
            BorderBrush="#4830363D"
            BorderThickness="1"
            CornerRadius="10">
        <StackPanel Margin="7,6">

            <!-- Header: name + badge + clock -->
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="CharacterNameText" Text="Character"
                               Foreground="#E6EDF3" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock x:Name="CharacterMetaText" Text="Lvl 0 | Class 0"
                               Foreground="#8B949E" FontFamily="Consolas" FontSize="10" Margin="0,1,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <Border x:Name="BotStateBadge" Background="#2A4E66" BorderBrush="#388BFD"
                            BorderThickness="1" CornerRadius="5" Padding="5,2" HorizontalAlignment="Right">
                        <TextBlock x:Name="BotStateText" Text="OFF"
                                   Foreground="#E6EDF3" FontFamily="Consolas" FontWeight="SemiBold" FontSize="10" />
                    </Border>
                    <TextBlock x:Name="ClockText" Text="00:00:00"
                               Foreground="#6E7681" FontFamily="Consolas" FontSize="10"
                               HorizontalAlignment="Right" Margin="0,3,0,0" />
                </StackPanel>
            </Grid>

            <Button x:Name="BotToggleButton"
                    Content="Start Bot"
                    Height="28"
                    Margin="0,0,0,6"
                    Foreground="#E6EDF3"
                    Background="#2A4E66"
                    BorderBrush="#7CC3FF"
                    BorderThickness="1"
                    FontFamily="Consolas"
                    FontWeight="SemiBold"
                    Click="OnBotToggleButtonClick" />

            <!-- Vitals -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="HP" Foreground="#FF7B72" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" />
                        <ProgressBar x:Name="HpBar" Grid.Column="1" Style="{StaticResource VitalBar}" VerticalAlignment="Center" />
                        <TextBlock x:Name="HpText" Grid.Column="2" Text="0/0 (0%)"
                                   Foreground="#C9D1D9" FontFamily="Consolas" FontSize="10" HorizontalAlignment="Right" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="MP" Foreground="#79C0FF" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" />
                        <ProgressBar x:Name="MpBar" Grid.Column="1" Style="{StaticResource VitalBar}" Foreground="#388BFD" VerticalAlignment="Center" />
                        <TextBlock x:Name="MpText" Grid.Column="2" Text="0/0 (0%)"
                                   Foreground="#C9D1D9" FontFamily="Consolas" FontSize="10" HorizontalAlignment="Right" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CP" Foreground="#D2A8FF" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" />
                        <ProgressBar x:Name="CpBar" Grid.Column="1" Style="{StaticResource VitalBar}" Foreground="#A371F7" VerticalAlignment="Center" />
                        <TextBlock x:Name="CpText" Grid.Column="2" Text="0/0 (0%)"
                                   Foreground="#C9D1D9" FontFamily="Consolas" FontSize="10" HorizontalAlignment="Right" />
                    </Grid>
                </Grid>
            </Border>

            <!-- Target -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,4">
                <StackPanel>
                    <TextBlock Text="TARGET" Style="{StaticResource SectionLabel}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TargetNameText" Text="No target"
                                   Foreground="#E6EDF3" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock x:Name="TargetHpText" Grid.Column="1" Text="HP --"
                                   Foreground="#8B949E" FontFamily="Consolas" FontSize="10" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock x:Name="TargetDetailsText" Text="Dist -- | OID --"
                               Foreground="#6E7681" FontFamily="Consolas" FontSize="10" Margin="0,1,0,3" />
                    <ProgressBar x:Name="TargetHpBar" Style="{StaticResource VitalBar}" Foreground="#F85149" />
                </StackPanel>
            </Border>

            <!-- Nearby -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,4">
                <StackPanel>
                    <TextBlock Text="NEARBY" Style="{StaticResource SectionLabel}" />
                    <TextBlock x:Name="NearbyMobsText" Text="Mobs: -"
                               Foreground="#C9D1D9" FontFamily="Consolas" FontSize="10"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="NearbyLootText" Text="Loot: -"
                               Foreground="#8B949E" FontFamily="Consolas" FontSize="10"
                               TextWrapping="Wrap" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <!-- Session -->
            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="SESSION" Style="{StaticResource SectionLabel}" Grid.ColumnSpan="2" />
                    <TextBlock x:Name="SessionKillsText" Grid.Row="1" Text="Kills: 0"
                               Foreground="#C9D1D9" FontFamily="Consolas" FontSize="10" />
                    <TextBlock x:Name="SessionLootText" Grid.Row="1" Grid.Column="1" Text="Loot: 0"
                               Foreground="#C9D1D9" FontFamily="Consolas" FontSize="10" HorizontalAlignment="Right" />
                    <TextBlock x:Name="SessionAdenaText" Grid.Row="2" Text="Adena: 0"
                               Foreground="#8B949E" FontFamily="Consolas" FontSize="10" Margin="0,2,0,0" />
                    <TextBlock x:Name="SessionTimeText" Grid.Row="2" Grid.Column="1" Text="00:00:00"
                               Foreground="#8B949E" FontFamily="Consolas" FontSize="10"
                               HorizontalAlignment="Right" Margin="0,2,0,0" />
                </Grid>
            </Border>

        </StackPanel>
    </Border>
</Window>
