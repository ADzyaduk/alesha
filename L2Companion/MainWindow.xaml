<Window x:Class="L2Companion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="L2 Companion"
        Height="820"
        Width="1200"
        MinHeight="680"
        MinWidth="960">

    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#60CDFF" />
        <SolidColorBrush x:Key="Good" Color="#6CCB5F" />
        <SolidColorBrush x:Key="Bad" Color="#FF6B6B" />
        <SolidColorBrush x:Key="Dim" Color="#888" />
        <SolidColorBrush x:Key="PanelBg" Color="#1E1E1E" />
        <SolidColorBrush x:Key="HeaderBg" Color="#111" />
        <SolidColorBrush x:Key="FieldBg" Color="#2A2A2E" />
        <SolidColorBrush x:Key="FieldBorder" Color="#3C3C42" />

        <!-- Override system colors so ComboBox popup, ListBox, DataGrid editing cells use dark background -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A2E" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#E8E8E8" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#1A3A5C" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#F0F0F0" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#2A3A4C" />

        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="Background" Value="{StaticResource FieldBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorder}" />
            <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
            <Setter Property="Padding" Value="5,3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="Background" Value="{StaticResource FieldBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorder}" />
            <Setter Property="Padding" Value="5,3" />
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
            <Setter Property="Background" Value="#2A2A2E" />
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="SemiBold" Foreground="{StaticResource Accent}" FontSize="13" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="Foreground" Value="#CCC" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="MinWidth" Value="52" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="Background" Value="#333338" />
            <Setter Property="BorderBrush" Value="#4A4A52" />
        </Style>

        <Style x:Key="BtnAdd" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1B5E20" />
            <Setter Property="Foreground" Value="#B9F6CA" />
            <Setter Property="BorderBrush" Value="#2E7D32" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="BtnDel" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#7F1D1D" />
            <Setter Property="Foreground" Value="#FCA5A5" />
            <Setter Property="BorderBrush" Value="#991B1B" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="Background" Value="#1A1A1E" />
            <Setter Property="RowBackground" Value="#222226" />
            <Setter Property="AlternatingRowBackground" Value="#28282E" />
            <Setter Property="Foreground" Value="#D0D0D0" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorder}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#333" />
            <Setter Property="HeadersVisibility" Value="Column" />
        </Style>

        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="Background" Value="#2A2A30" />
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderBrush" Value="#3A3A42" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="Foreground" Value="#D0D0D0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="4,2" />
        </Style>

        <Style TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorder}" />
        </Style>

        <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
            <Setter Property="Foreground" Value="#AAA" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="13" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Accent}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
            <Setter Property="Background" Value="#111" />
            <Setter Property="Foreground" Value="#CCC" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorder}" />
        </Style>

        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Setter Property="Foreground" Value="#D0D0D0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A3A5C" />
                    <Setter Property="Foreground" Value="#F0F0F0" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#181818">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== HEADER BAR ===== -->
        <Border Padding="12,8" Background="{StaticResource HeaderBg}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding Status}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Accent}" />
                    <TextBlock Text="{Binding ParserSummary}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource Dim}" Margin="0,2,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Role:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource Dim}" />
                    <ComboBox Width="110" ItemsSource="{Binding RoleOptions}" SelectedItem="{Binding Role}" Margin="0,0,10,0" />
                    <TextBlock Text="Mode:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource Dim}" />
                    <ComboBox Width="110" ItemsSource="{Binding BattleModeOptions}" SelectedItem="{Binding BattleMode}" Margin="0,0,14,0" />
                    <Button Content="Start Proxy" Command="{Binding StartProxyCommand}" Style="{StaticResource BtnAdd}" Margin="0,0,4,0" />
                    <Button Content="Stop Proxy" Command="{Binding StopProxyCommand}" Style="{StaticResource BtnDel}" Margin="0,0,8,0" />
                    <Button Content="Start Bot" Command="{Binding StartBotCommand}" Style="{StaticResource BtnAdd}" Margin="0,0,4,0" />
                    <Button Content="Stop Bot" Command="{Binding StopBotCommand}" Style="{StaticResource BtnDel}" Margin="0,0,8,0" />
                    <Button Content="Overlay" Command="{Binding ToggleOverlayCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== TOGGLE STRIP ===== -->
        <Border Grid.Row="1" Padding="10,5" Background="{StaticResource PanelBg}">
            <StackPanel Orientation="Horizontal">
                <CheckBox Content="Fight" IsChecked="{Binding AutoFight}" Margin="0,0,12,0" Foreground="{StaticResource Good}" />
                <CheckBox Content="Loot" IsChecked="{Binding AutoLoot}" Margin="0,0,12,0" Foreground="{StaticResource Good}" />
                <CheckBox Content="Heal" IsChecked="{Binding AutoHeal}" Margin="0,0,12,0" Foreground="{StaticResource Good}" />
                <CheckBox Content="Buff" IsChecked="{Binding AutoBuff}" Margin="0,0,12,0" Foreground="{StaticResource Good}" />
                <CheckBox Content="Rest" IsChecked="{Binding RestEnabled}" Margin="0,0,12,0" Foreground="{StaticResource Good}" />
                <CheckBox Content="Recharge" IsChecked="{Binding AutoRecharge}" Margin="0,0,16,0" Foreground="{StaticResource Good}" />
                <Border Width="1" Background="{StaticResource Dim}" Opacity="0.3" Margin="0,2,10,2" />
                <TextBlock Text="Range:" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,4,0" />
                <TextBox Width="104" Text="{Binding FightRange, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" />
                <TextBlock Text="Loot:" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,4,0" />
                <TextBox Width="104" Text="{Binding LootRange, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Border>

        <!-- ===== TABS ===== -->
        <TabControl Grid.Row="2" SelectedIndex="{Binding SelectedTabIndex}" Margin="4,4,4,4">

            <!-- ======================================== -->
            <!-- TAB 1: OVERVIEW                          -->
            <!-- ======================================== -->
            <TabItem Header="Overview">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <GroupBox Header="Character">
                            <StackPanel>
                                <TextBlock Text="{Binding CharacterSummary}" FontSize="16" FontWeight="SemiBold" Foreground="#E0E0E0" />
                                <TextBlock Text="{Binding ResourceSummary}" FontFamily="Consolas" Margin="0,3,0,0" Foreground="#CCC" />
                                <TextBlock Text="{Binding PositionSummary}" FontFamily="Consolas" Foreground="{StaticResource Dim}" />
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Grid.Column="2" Header="Session">
                            <StackPanel>
                                <TextBlock Text="{Binding ProxyStateSummary}" FontFamily="Consolas" Foreground="#CCC" />
                                <TextBlock Text="{Binding ProxyTrafficSummary}" FontFamily="Consolas" Foreground="{StaticResource Dim}" Margin="0,2,0,0" />
                                <TextBlock Text="{Binding SessionSummary}" FontFamily="Consolas" Foreground="{StaticResource Dim}" Margin="0,2,0,0" />
                            </StackPanel>
                        </GroupBox>
                    </Grid>

                    <GroupBox Grid.Row="1" Header="World" Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding WorldSummary}" FontSize="14" FontWeight="SemiBold" Foreground="#CCC" />
                            <TextBlock Text="{Binding ParserSummary}" FontFamily="Consolas" Margin="0,3,0,0" TextWrapping="Wrap" Foreground="{StaticResource Dim}" />
                        </StackPanel>
                    </GroupBox>

                    <Grid Grid.Row="2" Margin="0,4,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="Party Members" Margin="0">
                            <DataGrid ItemsSource="{Binding PartyRows}" MinHeight="100" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="Lvl" Binding="{Binding Level}" Width="50" />
                                    <DataGridTextColumn Header="HP" Binding="{Binding Hp}" Width="100" />
                                    <DataGridTextColumn Header="MP" Binding="{Binding Mp}" Width="100" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Grid.Column="2" Header="Known Skills" Margin="0">
                            <DataGrid ItemsSource="{Binding SkillRows}" MinHeight="100" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding SkillId}" Width="70" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="Lvl" Binding="{Binding Level}" Width="60" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Grid.Row="2" Header="Nearby NPCs" Margin="0">
                            <DataGrid ItemsSource="{Binding NpcRows}" MinHeight="100" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="NpcId" Binding="{Binding NpcId}" Width="70" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="HP" Binding="{Binding Hp}" Width="70" />
                                    <DataGridTextColumn Header="Dist" Binding="{Binding Dist}" Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Grid.Row="2" Grid.Column="2" Header="Ground Items" Margin="0">
                            <DataGrid ItemsSource="{Binding ItemRows}" MinHeight="100" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ItemId" Binding="{Binding ItemId}" Width="70" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="60" />
                                    <DataGridTextColumn Header="Dist" Binding="{Binding Dist}" Width="60" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ======================================== -->
            <!-- TAB 2: COMBAT                            -->
            <!-- ======================================== -->
            <TabItem Header="Combat">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <!-- Skill search -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Skill search:" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,6,0" />
                            <TextBox Width="260" Text="{Binding SkillFilterText, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="Learned only" IsChecked="{Binding OnlyKnownSkills}" Margin="12,0,0,0" />
                            <TextBlock Text="{Binding SkillPickerSummary}" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Dim}" FontFamily="Consolas" FontSize="11" />
                        </StackPanel>

                        <!-- ATTACK ROTATION -->
                        <TextBlock Text="Attack Rotation" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,2" />
                        <Border Height="1" Background="{StaticResource Accent}" Opacity="0.3" Margin="0,0,0,6" />

                        <Grid HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Skill" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,6,0" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding FilteredSkillPickerOptions}" DisplayMemberPath="Label" SelectedValuePath="SkillId" SelectedValue="{Binding NewAttackSkillId}" />
                            <TextBlock Grid.Column="2" Text="CD" VerticalAlignment="Center" Margin="6,0,4,0" Foreground="{StaticResource Dim}" />
                            <TextBox Grid.Column="3" Text="{Binding NewAttackCooldownMs, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="4" Text="Pri" VerticalAlignment="Center" Margin="6,0,4,0" Foreground="{StaticResource Dim}" />
                            <TextBox Grid.Column="5" Text="{Binding NewAttackPriority, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Grid.Column="6" Content="On" IsChecked="{Binding NewAttackRuleEnabled}" Margin="6,0,0,0" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="Add" Command="{Binding AddAttackRuleCommand}" Style="{StaticResource BtnAdd}" Margin="0,0,4,0" />
                            <Button Content="Remove" Command="{Binding RemoveAttackRuleCommand}" Style="{StaticResource BtnDel}" Margin="0,0,4,0" />
                            <Button Content="Up" Command="{Binding MoveAttackUpCommand}" Margin="0,0,4,0" />
                            <Button Content="Down" Command="{Binding MoveAttackDownCommand}" />
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding AttackRuleRows}" SelectedItem="{Binding SelectedAttackRule}" MinHeight="140" Margin="0,6,0,0" AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Order}" Width="32" IsReadOnly="True" />
                                <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" Width="40" />
                                <DataGridTextColumn Header="Pri" Binding="{Binding Priority, UpdateSourceTrigger=PropertyChanged}" Width="40" />
                                <DataGridTextColumn Header="Id" Binding="{Binding SkillId}" Width="60" />
                                <DataGridTextColumn Header="Skill" Binding="{Binding SkillName}" Width="*" IsReadOnly="True" />
                                <DataGridTextColumn Header="CD" Binding="{Binding CooldownMs, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                                <DataGridTextColumn Header="≥MP" Binding="{Binding MinMpPct, UpdateSourceTrigger=PropertyChanged}" Width="42" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- SPOIL / SWEEP -->
                        <TextBlock Text="Spoil / Sweep" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,14,0,2" />
                        <Border Height="1" Background="{StaticResource Accent}" Opacity="0.3" Margin="0,0,0,6" />

                        <Grid MaxWidth="700" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" MinWidth="160" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" MinWidth="160" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <CheckBox Content="Spoil" IsChecked="{Binding SpoilEnabled}" Margin="0,0,6,4" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding FilteredSkillPickerOptions}" DisplayMemberPath="Label" SelectedValuePath="SkillId" SelectedValue="{Binding SpoilSkillId}" Margin="0,0,0,4" />
                            <CheckBox Grid.Column="3" Content="Sweep" IsChecked="{Binding SweepEnabled}" Margin="0,0,6,4" />
                            <ComboBox Grid.Column="4" ItemsSource="{Binding FilteredSkillPickerOptions}" DisplayMemberPath="Label" SelectedValuePath="SkillId" SelectedValue="{Binding SweepSkillId}" Margin="0,0,0,4" />
                            <CheckBox Grid.Row="1" Content="Cap spoil tries" IsChecked="{Binding SpoilOncePerTarget}" Margin="0,0,12,4" VerticalAlignment="Center" ToolTip="Off = retry Spoil until it succeeds (like putting Spoil in rotation). On = stop after Max tries." />
                            <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Max tries" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,6,0" />
                                <TextBox Width="44" Text="{Binding SpoilMaxAttemptsPerTarget, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="(when Cap on)" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="8,0,0,0" FontSize="11" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Spoil retry ms" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,6,0" />
                                <TextBox Width="52" Text="{Binding SpoilRetryIntervalMs, UpdateSourceTrigger=PropertyChanged}" ToolTip="Minimum gap between Spoil packets (default 1500). Out-of-range walks do not count as tries." />
                                <TextBlock Text="Cast range" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="16,0,6,0" />
                                <TextBox Width="52" Text="{Binding SpoilMaxCastDistance, UpdateSourceTrigger=PropertyChanged}" ToolTip="Planar XY distance — Spoil is not sent until you are this close (default 600)." />
                            </StackPanel>
                        </Grid>

                        <!-- REST THRESHOLDS -->
                        <TextBlock Text="Rest (Sit/Stand)" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,14,0,2" />
                        <Border Height="1" Background="{StaticResource Accent}" Opacity="0.3" Margin="0,0,0,6" />

                        <Grid MaxWidth="480" HorizontalAlignment="Left">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Text="Sit MP ≤ %" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,6,0" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SitMpPct, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Stand MP ≥ %" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,6,0" />
                            <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding StandMpPct, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="1" Text="Sit HP ≤ %" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,6,6,0" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RestSitHpPct, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" />
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="Stand HP ≥ %" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,6,6,0" />
                            <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding RestStandHpPct, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" />
                        </Grid>

                        <!-- MONSTER FILTERS -->
                        <TextBlock Text="Monster Filters" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,14,0,2" />
                        <Border Height="1" Background="{StaticResource Accent}" Opacity="0.3" Margin="0,0,0,6" />

                        <WrapPanel Margin="0,0,0,4">
                            <CheckBox Content="Prefer aggro" IsChecked="{Binding PreferAggroMobs}" Margin="0,0,12,4" />
                            <CheckBox Content="Whitelist only" IsChecked="{Binding AttackOnlyWhitelistMobs}" Margin="0,0,12,4" />
                            <CheckBox Content="Skip summoned" IsChecked="{Binding SkipSummonedNpcs}" Margin="0,0,12,4" />
                        </WrapPanel>
                        <Grid MaxWidth="520" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Whitelist NPC IDs" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,8,4" />
                            <TextBox Grid.Column="1" Text="{Binding NpcWhitelistCsv, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                            <TextBlock Grid.Row="1" Text="Blacklist NPC IDs" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,8,4" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NpcBlacklistCsv, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                        </Grid>

                        <!-- ADVANCED (collapsed) -->
                        <Expander Header="Advanced Combat Settings" IsExpanded="False" Margin="0,10,0,0">
                            <Grid Margin="6,6,0,0" MaxWidth="600" HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Melee range" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,6,4" />
                                <TextBox Grid.Column="1" Text="{Binding MeleeEngageRange, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                                <TextBlock Grid.Column="3" Text="Z range" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,6,4" />
                                <TextBox Grid.Column="4" Text="{Binding TargetZRangeMax, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                                <TextBlock Grid.Row="1" Text="Retain dist" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,6,4" />
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RetainCurrentTargetMaxDist, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                                <TextBlock Grid.Row="1" Grid.Column="3" Text="Hunt center" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,6,4" />
                                <ComboBox Grid.Row="1" Grid.Column="4" ItemsSource="{Binding HuntCenterModeOptions}" SelectedItem="{Binding HuntCenterMode}" Margin="0,0,0,4" />
                                <TextBlock Grid.Row="2" Text="Pickup range" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,6,4" />
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding LootPickupRange, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                                <TextBlock Grid.Row="3" Text="Kill timeout ms" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,6,4" />
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding KillTimeoutMs, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                            </Grid>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ======================================== -->
            <!-- TAB 3: SUPPORT (Heal + Buff + Recharge + Party) -->
            <!-- ======================================== -->
            <TabItem Header="Support">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <!-- PARTY BEHAVIOR -->
                        <WrapPanel Margin="0,0,0,8">
                            <CheckBox Content="Party support" IsChecked="{Binding PartySupportEnabled}" Margin="0,0,12,0" />
                            <CheckBox Content="Assist + Follow" IsChecked="{Binding AssistFollowEnabled}" Margin="0,0,12,0" />
                            <CheckBox Content="Leader broadcast" IsChecked="{Binding LeaderBroadcastEnabled}" Margin="0,0,12,0" />
                        </WrapPanel>

                        <!-- SELF HEAL -->
                        <TextBlock Text="Self Heal Rules" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,2" />
                        <Border Height="1" Background="{StaticResource Accent}" Opacity="0.3" Margin="0,0,0,6" />

                        <Grid HorizontalAlignment="Stretch" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" MinWidth="160" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="68" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Skill" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,6,0" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding FilteredSkillPickerOptions}" DisplayMemberPath="Label" SelectedValuePath="SkillId" SelectedValue="{Binding NewHealSkillId}" />
                            <TextBlock Grid.Column="2" Text="HP≤" VerticalAlignment="Center" Margin="6,0,4,0" Foreground="{StaticResource Dim}" />
                            <TextBox Grid.Column="3" Text="{Binding NewHealHpBelowPct, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="4" Text="CD" VerticalAlignment="Center" Margin="6,0,4,0" Foreground="{StaticResource Dim}" />
                            <TextBox Grid.Column="5" Text="{Binding NewHealCooldownMs, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="6" Content="Add" Command="{Binding AddHealRuleCommand}" Style="{StaticResource BtnAdd}" Margin="6,0,4,0" />
                            <Button Grid.Column="7" Content="Del" Command="{Binding RemoveHealRuleCommand}" Style="{StaticResource BtnDel}" />
                        </Grid>
                        <DataGrid ItemsSource="{Binding HealRuleRows}" SelectedItem="{Binding SelectedHealRule}" MinHeight="90" AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="40" />
                                <DataGridTextColumn Header="HP≤" Binding="{Binding HpBelowPct}" Width="50" />
                                <DataGridTextColumn Header="Id" Binding="{Binding SkillId}" Width="60" />
                                <DataGridTextColumn Header="Skill" Binding="{Binding SkillName}" Width="*" IsReadOnly="True" />
                                <DataGridTextColumn Header="CD" Binding="{Binding CooldownMs}" Width="60" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- PARTY HEAL -->
                        <TextBlock Text="Party Heal Rules" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,12,0,2" />
                        <Border Height="1" Background="{StaticResource Accent}" Opacity="0.3" Margin="0,0,0,6" />

                        <Grid HorizontalAlignment="Stretch" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" MinWidth="160" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="68" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Skill" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,6,0" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding FilteredSkillPickerOptions}" DisplayMemberPath="Label" SelectedValuePath="SkillId" SelectedValue="{Binding NewPartyHealSkillId}" />
                            <TextBlock Grid.Column="2" Text="Mode" VerticalAlignment="Center" Margin="6,0,4,0" Foreground="{StaticResource Dim}" />
                            <ComboBox Grid.Column="3" ItemsSource="{Binding PartyHealModeOptions}" SelectedItem="{Binding NewPartyHealMode}" />
                            <TextBlock Grid.Column="4" Text="HP≤" VerticalAlignment="Center" Margin="6,0,4,0" Foreground="{StaticResource Dim}" />
                            <TextBox Grid.Column="5" Text="{Binding NewPartyHealHpBelowPct, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="6" Text="CD" VerticalAlignment="Center" Margin="6,0,4,0" Foreground="{StaticResource Dim}" />
                            <TextBox Grid.Column="7" Text="{Binding NewPartyHealCooldownMs, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="8" Content="Add" Command="{Binding AddPartyHealRuleCommand}" Style="{StaticResource BtnAdd}" Margin="6,0,4,0" />
                            <Button Grid.Column="9" Content="Del" Command="{Binding RemovePartyHealRuleCommand}" Style="{StaticResource BtnDel}" />
                        </Grid>
                        <DataGrid ItemsSource="{Binding PartyHealRuleRows}" SelectedItem="{Binding SelectedPartyHealRule}" MinHeight="90" AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="40" />
                                <DataGridComboBoxColumn Header="Mode"
                                                        SelectedItemBinding="{Binding Mode}"
                                                        ItemsSource="{Binding DataContext.PartyHealModeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        Width="100" />
                                <DataGridTextColumn Header="HP≤" Binding="{Binding HpBelowPct}" Width="50" />
                                <DataGridTextColumn Header="Id" Binding="{Binding SkillId}" Width="60" />
                                <DataGridTextColumn Header="Skill" Binding="{Binding SkillName}" Width="*" IsReadOnly="True" />
                                <DataGridTextColumn Header="CD" Binding="{Binding CooldownMs}" Width="60" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- BUFF RULES -->
                        <TextBlock Text="Buff Rules" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,12,0,2" />
                        <Border Height="1" Background="{StaticResource Accent}" Opacity="0.3" Margin="0,0,0,6" />
                        <TextBlock Text="Scope: Self / Party / Both.  AutoDetect re-buffs when effect expires." FontSize="11" Foreground="{StaticResource Dim}" Margin="0,0,0,4" />

                        <Grid HorizontalAlignment="Stretch" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" MinWidth="160" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Skill" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,6,0" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding FilteredSkillPickerOptions}" DisplayMemberPath="Label" SelectedValuePath="SkillId" SelectedValue="{Binding NewBuffSkillId}" />
                            <TextBlock Grid.Column="2" Text="Scope" VerticalAlignment="Center" Margin="6,0,4,0" Foreground="{StaticResource Dim}" />
                            <ComboBox Grid.Column="3" ItemsSource="{Binding BuffScopeOptions}" SelectedItem="{Binding NewBuffScope}" />
                            <CheckBox Grid.Column="4" Content="Auto" IsChecked="{Binding NewBuffAutoDetect}" Margin="6,0,0,0" />
                            <TextBlock Grid.Column="5" Text="Delay s" VerticalAlignment="Center" Margin="6,0,4,0" Foreground="{StaticResource Dim}" />
                            <TextBox Grid.Column="6" Text="{Binding NewBuffDelaySec, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="7" Content="Add" Command="{Binding AddBuffRuleCommand}" Style="{StaticResource BtnAdd}" Margin="6,0,4,0" />
                            <Button Grid.Column="8" Content="Del" Command="{Binding RemoveBuffRuleCommand}" Style="{StaticResource BtnDel}" />
                        </Grid>
                        <DataGrid ItemsSource="{Binding BuffRuleRows}" SelectedItem="{Binding SelectedBuffRule}" MinHeight="90" AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="40" />
                                <DataGridTextColumn Header="Id" Binding="{Binding SkillId}" Width="60" />
                                <DataGridTextColumn Header="Skill" Binding="{Binding SkillName}" Width="*" IsReadOnly="True" />
                                <DataGridComboBoxColumn Header="Scope"
                                                        SelectedItemBinding="{Binding Scope}"
                                                        ItemsSource="{Binding DataContext.BuffScopeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        Width="100" />
                                <DataGridCheckBoxColumn Header="Auto" Binding="{Binding AutoDetect}" Width="50" />
                                <DataGridTextColumn Header="Delay" Binding="{Binding DelaySec}" Width="50" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- RECHARGE RULES -->
                        <TextBlock Text="Recharge Rules (MP Restore)" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,12,0,2" />
                        <Border Height="1" Background="{StaticResource Accent}" Opacity="0.3" Margin="0,0,0,6" />

                        <Grid HorizontalAlignment="Stretch" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" MinWidth="160" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="68" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Skill" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,6,0" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding FilteredSkillPickerOptions}" DisplayMemberPath="Label" SelectedValuePath="SkillId" SelectedValue="{Binding NewRechargeSkillId}" />
                            <TextBlock Grid.Column="2" Text="MP≤" VerticalAlignment="Center" Margin="6,0,4,0" Foreground="{StaticResource Dim}" />
                            <TextBox Grid.Column="3" Text="{Binding NewRechargeMpBelowPct, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="4" Text="CD" VerticalAlignment="Center" Margin="6,0,4,0" Foreground="{StaticResource Dim}" />
                            <TextBox Grid.Column="5" Text="{Binding NewRechargeCooldownMs, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="6" Content="Add" Command="{Binding AddRechargeRuleCommand}" Style="{StaticResource BtnAdd}" Margin="6,0,4,0" />
                            <Button Grid.Column="7" Content="Del" Command="{Binding RemoveRechargeRuleCommand}" Style="{StaticResource BtnDel}" />
                        </Grid>
                        <DataGrid ItemsSource="{Binding RechargeRuleRows}" SelectedItem="{Binding SelectedRechargeRule}" MinHeight="80" AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="40" />
                                <DataGridTextColumn Header="Id" Binding="{Binding SkillId}" Width="60" />
                                <DataGridTextColumn Header="Skill" Binding="{Binding SkillName}" Width="*" IsReadOnly="True" />
                                <DataGridTextColumn Header="MP≤" Binding="{Binding MpBelowPct}" Width="50" />
                                <DataGridTextColumn Header="CD" Binding="{Binding CooldownMs}" Width="60" />
                                <DataGridTextColumn Header="Self MP%" Binding="{Binding MinSelfMpPct}" Width="70" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- CRITICAL HOLD / DEAD STOP -->
                        <Expander Header="Critical HP &amp; Recovery Thresholds" IsExpanded="False" Margin="0,10,0,0">
                            <Grid Margin="6,6,0,0" MaxWidth="500" HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" MinWidth="80" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Dead stop resume HP%" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,8,4" />
                                <TextBox Grid.Column="1" Text="{Binding DeadStopResumeHpPct, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                                <TextBlock Grid.Row="1" Text="Critical hold enter HP%" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,8,4" />
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CriticalHoldEnterHpPct, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                                <TextBlock Grid.Row="2" Text="Critical hold resume HP%" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,8,4" />
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CriticalHoldResumeHpPct, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                                <TextBlock Grid.Row="3" Text="Self heal HP trigger %" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,8,4" />
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding HealThreshold, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                                <TextBlock Grid.Row="4" Text="Self heal skill" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,8,4" />
                                <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding FilteredSkillPickerOptions}" DisplayMemberPath="Label" SelectedValuePath="SkillId" SelectedValue="{Binding SelfHealSkillId}" Margin="0,0,0,4" />
                            </Grid>
                        </Expander>

                        <!-- COORDINATOR (collapsed) -->
                        <Expander Header="Coordinator / Follow" IsExpanded="False" Margin="0,6,0,0">
                            <Grid Margin="6,6,0,0" MaxWidth="420" HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Coord mode" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,8,4" />
                                <ComboBox Grid.Column="1" ItemsSource="{Binding CoordModeOptions}" SelectedItem="{Binding CoordMode}" Margin="0,0,0,4" />
                                <TextBlock Grid.Row="1" Text="Channel" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,8,4" />
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CoordinatorChannel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                                <TextBlock Grid.Row="2" Text="Follow distance" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,8,4" />
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding FollowDistance, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                                <TextBlock Grid.Row="3" Text="Follow tolerance" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,8,4" />
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding FollowTolerance, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                                <CheckBox Grid.Row="4" Content="Fallback to solo" IsChecked="{Binding FollowerFallbackToStandalone}" Margin="0,0,0,4" />
                            </Grid>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ======================================== -->
            <!-- TAB 4: CONNECTION + LOGS                 -->
            <!-- ======================================== -->
            <TabItem Header="Connection + Logs">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Proxy Endpoints" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,2" />

                    <Grid Grid.Row="1" MaxWidth="420" HorizontalAlignment="Left" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Login host" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,8,4" />
                        <TextBox Grid.Column="1" Text="{Binding LoginHost, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="1" Text="Login port" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,8,4" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding LoginPort, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="2" Text="Game host" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,8,4" />
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding GameHost, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="3" Text="Game port" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,8,4" />
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding GamePort, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="4" Text="Local login port" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,8,4" />
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding LocalLoginPort, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="5" Text="Local game port" VerticalAlignment="Center" Foreground="{StaticResource Dim}" Margin="0,0,8,4" />
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding LocalGamePort, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />
                    </Grid>

                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <TextBlock Text="{Binding ProxyStateSummary}" FontFamily="Consolas" Foreground="#CCC" />
                        <TextBlock Text="{Binding ProxyTrafficSummary}" FontFamily="Consolas" Foreground="{StaticResource Dim}" />
                        <TextBlock Text="{Binding LastErrorSummary}" FontFamily="Consolas" Foreground="{StaticResource Bad}" />
                    </StackPanel>

                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="Copy" Command="{Binding CopyLogsCommand}" Margin="0,0,4,0" />
                            <Button Content="Export" Command="{Binding ExportLogsCommand}" Margin="0,0,4,0" />
                            <Button Content="Clear" Command="{Binding ClearLogsCommand}" />
                        </StackPanel>

                        <ListBox Grid.Row="1"
                                 x:Name="LogList"
                                 ItemsSource="{Binding Logs}"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.CanContentScroll="True"
                                 Background="#111"
                                 BorderBrush="{StaticResource FieldBorder}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontFamily="Consolas" FontSize="11">
                                        <Run Text="{Binding Time, StringFormat={}{0:HH:mm:ss}}" Foreground="{StaticResource Dim}" />
                                        <Run Text="  " />
                                        <Run Text="{Binding Message}" Foreground="#CCC" />
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
